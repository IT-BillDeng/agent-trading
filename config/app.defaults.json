{
  "_comment": "Project defaults - merge order: defaults <- docker overlay <- user settings <- env-backed secrets",
  "mode": "paper",
  "markets": [
    "US"
  ],
  "broker": {
    "platform": "tiger"
  },
  "strategy": {
    "timeframe": "30min",
    "use_rule_engine": true,
    "market_data": {
      "include_extended_hours": true,
      "extended_hours_usage": "context_only",
      "regular_session_only_for_indicators": true,
      "require_completed_bar_for_actionable_signal": true
    },
    "data_provider": {
      "primary": "yfinance",
      "fallback": "tiger",
      "fail_on_empty_bars": false
    },
    "signal": {
      "lookback_bars": 30,
      "fast_sma": 5,
      "slow_sma": 10,
      "trend_sma": 20,
      "min_momentum_3bars": 0.003,
      "max_bar_range_pct": 0.04
    },
    "sessions": {
      "US": {
        "regular_start": "09:30",
        "regular_end": "16:00",
        "entry_window_start": "10:00",
        "entry_window_end": "15:15",
        "timezone": "America/New_York"
      }
    },
    "symbols": [
      {
        "symbol": "AAPL",
        "market": "US",
        "name": "Apple"
      },
      {
        "symbol": "MSFT",
        "market": "US",
        "name": "Microsoft"
      },
      {
        "symbol": "NVDA",
        "market": "US",
        "name": "NVIDIA"
      },
      {
        "symbol": "AMZN",
        "market": "US",
        "name": "Amazon"
      },
      {
        "symbol": "SMCI",
        "market": "US",
        "name": "Super Micro Computer"
      },
      {
        "symbol": "GOOGL",
        "market": "US",
        "name": "Alphabet Class A"
      }
    ]
  },
  "risk": {
    "max_order_notional_usd": 10000,
    "daily_loss_limit_pct": 5,
    "max_total_exposure_usd": 100000,
    "max_trades_per_day": 10,
    "max_trades_per_symbol_per_day": 3,
    "symbol_cooldown_minutes_after_order": 30,
    "symbol_cooldown_minutes_after_loss": 120,
    "fx_rates_to_usd": {
      "USD": 1.0
    },
    "allow_short": false,
    "allow_margin": false,
    "disable_leverage": true,
    "allow_options": false
  },
  "execution": {
    "allowed_order_types": [
      "MKT",
      "LMT",
      "STP",
      "STP_LMT"
    ],
    "tif": "DAY",
    "allow_prepost": false,
    "dedupe": true,
    "preview_check": true,
    "submit_mode": "guarded",
    "live_submit": false,
    "live_cancel": false
  },
  "notify": {
    "telegram": true,
    "telegram_preview_only": false,
    "telegram_send_enabled": true,
    "telegram_target": "${ENGINE_TELEGRAM_TARGET}",
    "ntfy": false
  },
  "system": {
    "stop_on_exception": true,
    "auto_resume": false,
    "resume_requires_manual_unlock": true
  }
}
