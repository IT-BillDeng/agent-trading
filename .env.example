TZ=Asia/Shanghai
ENGINE_BROKER=tiger
ENGINE_CONFIG_DIR=/app/config
ENGINE_RULES_DIR=/app/rules
ENGINE_NEWS_DIR=/app/news
TIGER_PROPERTIES_DIR=/app/properties
ENGINE_WORKSPACE=/app
ENGINE_WATCHLIST_PATH=/app/data/watchlist.json
ENGINE_QUOTE_PROVIDER=yfinance
ENGINE_LOGS_DIR=/app/logs
ENGINE_RUNTIME_DIR=/app/runtime
ENGINE_APP_CONFIG=/app/config/app_config.docker.json
ENGINE_SCHEDULER_PROVIDER=yfinance
ENGINE_SCHEDULER_INTERVAL=60
ENGINE_ARTIFACTS_DIR=/app/artifacts
ENGINE_MAIN_AGENT_SESSION_KEY=agent:main
DASHBOARD_HOST=127.0.0.1
DASHBOARD_PORT=8088
DASHBOARD_ENABLE_CONFIG_UPLOAD=false

# Private target used by telegram dispatch / cron delivery
# Set this to your own chat_id or user id in the local .env
ENGINE_TELEGRAM_TARGET=
