  "description": "Sanitized sample rules for tests and local paper-first research. Copy to rules/rules.json before running the dashboard locally.",
  "rules": [
    {
      "rule_id": "trend_follow_30m",
      "name": "30-minute trend-following sample",
      "description": "A disabled sample trend-following rule that demonstrates SMA, momentum, and range filters.",
      "enabled": false,
      "priority": 1,
      "timeframe": "30min",
      "symbols": ["*"],
      "markets": ["US"],
      "entry": {
        "conditions": {
          "operator": "AND",
          "items": [
            {
              "type": "indicator",
              "indicator": "sma",
              "params": {"period": 5},
              "compare": {"field": "close", "operator": "above"}
            },
            {
              "type": "indicator",
              "indicator": "sma",
              "params": {"period": 5},
              "compare": {"indicator": "sma", "params": {"period": 10}, "operator": "above"}
            },
            {
              "type": "indicator",
              "indicator": "sma",
              "params": {"period": 10},
              "compare": {"indicator": "sma", "params": {"period": 20}, "operator": "above"}
            },
            {
              "type": "indicator",
              "indicator": "momentum",
              "params": {"period": 3},
              "compare": {"operator": "above", "value": 0.003}
            },
            {
              "type": "indicator",
              "indicator": "bar_range_pct",
              "compare": {"operator": "below", "value": 0.04}
            }
          ]
        },
        "action": "BUY",
        "order_type": "LMT",
        "stop_loss_pct": 0.03,
        "take_profit_pct": 0.06
      },
      "exit": {
        "conditions": {
          "operator": "OR",
          "items": [
            {
              "type": "indicator",
              "indicator": "sma",
              "params": {"period": 5},
              "compare": {"field": "close", "operator": "below"}
            },
            {
              "type": "indicator",
              "indicator": "sma",
              "params": {"period": 5},
              "compare": {"indicator": "sma", "params": {"period": 10}, "operator": "below"}
            }
          ]
        },
        "action": "EXIT",
        "order_type": "MKT"
      },
      "search_space": {
        "sma_short": {"min": 3, "max": 10, "step": 1, "path": "entry.conditions.items[0].params.period"},
        "sma_mid": {"min": 5, "max": 20, "step": 5, "path": "entry.conditions.items[1].params.period"},
        "sma_long": {"min": 10, "max": 30, "step": 5, "path": "entry.conditions.items[2].params.period"},
        "momentum_period": {"min": 2, "max": 5, "step": 1, "path": "entry.conditions.items[3].params.period"},
        "momentum_threshold": {"min": 0.001, "max": 0.005, "step": 0.001, "path": "entry.conditions.items[3].compare.value"},
        "bar_range_threshold": {"min": 0.02, "max": 0.06, "step": 0.01, "path": "entry.conditions.items[4].compare.value"}
      }
    },
    {
      "rule_id": "rsi_reversal",
      "name": "RSI reversal sample",
      "description": "A sample RSI cross-above rule for paper research and tests.",
      "enabled": true,
      "priority": 2,
      "timeframe": "30min",
      "symbols": ["*"],
      "markets": ["US"],
      "entry": {
        "conditions": {
          "operator": "AND",
          "items": [
            {
              "type": "indicator",
              "indicator": "rsi",
              "params": {"period": 14},
              "compare": {"operator": "cross_above", "value": 30}
            }
          ]
        },
        "action": "BUY",
        "order_type": "LMT",
        "stop_loss_pct": 0.02,
        "take_profit_pct": 0.04
      },
      "exit": {
        "conditions": {
          "operator": "OR",
          "items": [
            {
              "type": "indicator",
              "indicator": "rsi",
              "params": {"period": 14},
              "compare": {"operator": "above", "value": 75}
            },
            {"type": "stop_loss", "threshold_pct": 0.02}
          ]
        },
        "action": "EXIT",
        "order_type": "MKT"
      }
    },
    {
      "rule_id": "bollinger_breakout",
      "name": "Bollinger breakout sample",
      "description": "A sample Bollinger Band breakout rule with a volume filter.",
      "enabled": true,
      "priority": 3,
      "timeframe": "30min",
      "symbols": ["*"],
      "markets": ["US"],
      "entry": {
        "conditions": {
          "operator": "AND",
          "items": [
            {
              "type": "indicator",
              "indicator": "bollinger",
              "params": {"period": 20, "std_dev": 2},
              "compare": {"field": "close", "operator": "above_upper"}
            },
            {"type": "volume", "operator": "above_avg", "ratio": 1.2}
          ]
        },
        "action": "BUY",
        "order_type": "LMT",
        "stop_loss_pct": 0.025,
        "take_profit_pct": 0.05
      },
      "exit": {
        "conditions": {
          "operator": "OR",
          "items": [
            {
              "type": "indicator",
              "indicator": "bollinger",
              "params": {"period": 20, "std_dev": 2},
              "compare": {"field": "close", "operator": "below_middle"}
            },
            {"type": "stop_loss", "threshold_pct": 0.025}
          ]
        },
        "action": "EXIT",
        "order_type": "MKT"
      }
    }
  ],
