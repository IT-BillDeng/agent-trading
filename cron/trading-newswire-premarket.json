{
  "name": "trading-newswire-premarket",
  "description": "US 盘前新闻扫描（v3优化：web_fetch优先+批量搜索≤2次）",
  "schedule": {
    "kind": "cron",
    "expr": "0 9 * * 1-5",
    "tz": "America/New_York"
  },
  "sessionTarget": "isolated",
  "payload": {
    "kind": "agentTurn",
    "model": "openai-codex/gpt-5.4-mini",
    "timeoutSeconds": 300,
    "message": "读取 taskFile 并执行：/workspace/agent-trading/docs/tasks/cron/newswire-premarket.md",
    "taskFile": "/workspace/agent-trading/docs/tasks/cron/newswire-premarket.md"
  },
  "delivery": {
    "mode": "none"
  }
}
