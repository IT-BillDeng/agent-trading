{
  "name": "trading-watcher",
  "description": "系统健康监护人 - 每 15 分钟通过 API 检查系统状态",
  "schedule": {
    "kind": "cron",
    "expr": "*/15 * * * *",
    "tz": "America/New_York"
  },
  "sessionTarget": "isolated",
  "wakeMode": "now",
  "payload": {
    "kind": "agentTurn",
    "message": "读取 taskFile 并执行：/workspace/agent-trading/docs/tasks/cron/watcher.md",
    "timeoutSeconds": 200,
    "model": "openai-codex/gpt-5.4-mini",
    "taskFile": "/workspace/agent-trading/docs/tasks/cron/watcher.md"
  },
  "delivery": {
    "mode": "none"
  }
}
